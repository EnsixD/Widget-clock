<Window x:Class="WidgetClock.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WidgetClock"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="{Binding AlwaysOnTop}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Opacity="{Binding WindowOpacity}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonUp="Window_RightClick"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <!-- Custom context menu popup -->
    <Window.Resources>
        <Style x:Key="MenuItemBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFE0E0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,9,14,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="4,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2A8B85FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Clock widget -->
        <Border x:Name="RootBorder"
                CornerRadius="{Binding CornerRadius}"
                Background="{Binding BackgroundBrush}"
                Padding="{Binding WidgetPadding}"
                MinWidth="80">
            <Border.Effect>
                <DropShadowEffect x:Name="ShadowEffect"
                                  BlurRadius="30"
                                  Opacity="0.5"
                                  ShadowDepth="6"
                                  Color="Black"/>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding TimeText}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="{Binding FontSize}"
                           Foreground="{Binding TimeBrush}"
                           FontWeight="Light"
                           TextAlignment="Center"/>
                <TextBlock Text="{Binding DateText}"
                           Visibility="{Binding DateVisibility}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="{Binding DateFontSize}"
                           Foreground="{Binding DateBrush}"
                           TextAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Context menu popup -->
        <Popup x:Name="ContextPopup"
               Placement="Mouse"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade">
            <Border Background="#F01C1C2E"
                    CornerRadius="10"
                    BorderBrush="#28FFFFFF"
                    BorderThickness="1"
                    Padding="0,6,0,6"
                    MinWidth="190">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" Opacity="0.55" ShadowDepth="4" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Settings -->
                    <Button Style="{StaticResource MenuItemBtn}" Click="Settings_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#FF8B85FF"/>
                            <TextBlock Text="Настройки" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Divider -->
                    <Border Height="1" Background="#18FFFFFF" Margin="10,3,10,3"/>

                    <!-- Lock position — with indicator -->
                    <Button x:Name="LockBtn" Style="{StaticResource MenuItemBtn}" Click="LockPosition_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LockIcon" Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" Foreground="#FF8B85FF"/>
                            <TextBlock Grid.Column="1" x:Name="LockLabel" Text="Заблокировать"
                                       VerticalAlignment="Center"/>
                            <Ellipse x:Name="LockDot" Grid.Column="2" Width="6" Height="6"
                                     Fill="#FF6C63FF" VerticalAlignment="Center"
                                     Visibility="Collapsed"/>
                        </Grid>
                    </Button>

                    <!-- Always on top -->
                    <Button x:Name="TopBtn" Style="{StaticResource MenuItemBtn}" Click="AlwaysOnTop_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" Foreground="#FF8B85FF"/>
                            <TextBlock Grid.Column="1" Text="Поверх окон" VerticalAlignment="Center"/>
                            <Ellipse x:Name="TopDot" Grid.Column="2" Width="6" Height="6"
                                     Fill="#FF6C63FF" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- Divider -->
                    <Border Height="1" Background="#18FFFFFF" Margin="10,3,10,3"/>

                    <!-- Exit -->
                    <Button Style="{StaticResource MenuItemBtn}" Click="Exit_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#FF6655CC"/>
                            <TextBlock Text="Закрыть" VerticalAlignment="Center" Foreground="#FFCC9999"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
